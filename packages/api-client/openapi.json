  "info": {
    "title": "VETAPP API",
    "description": "API do VETAPP — versionada (/api/v1 nas próximas iterações)",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "tenantName": {
            "type": "string",
            "example": "Clínica Cuidar"
          },
          "email": {
            "type": "string",
            "example": "dono@clinica.com"
          },
          "name": {
            "type": "string",
            "example": "Maria Dona"
          },
          "password": {
            "type": "string",
            "example": "senha-forte-aqui",
            "minLength": 8
          }
        },
        "required": [
          "tenantName",
          "email",
          "name",
          "password"
        ]
      },
      "TokensDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "dono@clinica.com"
          },
          "password": {
            "type": "string",
            "example": "senha-forte-aqui"
          },
          "tenantId": {
            "type": "string",
            "description": "Tenant ativo (quando o usuário pertence a mais de um)"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthMeDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "tenantId": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "example": "admin"
          }
        },
        "required": [
          "userId",
          "tenantId",
          "role"
        ]
      },
      "ResponsavelDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "codigo": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "documento": {
            "type": "string"
          },
          "origem": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "nome"
        ]
      },
      "ListResponsaveisDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResponsavelDto"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          }
        },
        "required": [
          "items",
          "total",
          "page",
          "pageSize"
        ]
      },
      "CreateResponsavelDto": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string",
            "example": "Maria Silva"
          },
          "codigo": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "example": "maria@email.com"
          },
          "telefone": {
            "type": "string",
            "example": "+55 11 99999-0000"
          },
