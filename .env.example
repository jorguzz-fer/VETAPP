# ───────── API ─────────
NODE_ENV=development
# API em 3333 para não colidir com o Next (front) em 3000.
API_PORT=3333
# Origem permitida do front (CORS). Múltiplas separadas por vírgula.
CORS_ORIGINS=http://localhost:3000

# ───────── Banco de dados (Postgres) ─────────
# Usuário da aplicação: NÃO deve ter BYPASSRLS (ver docs/spec/03-multitenancy.md)
DATABASE_URL=postgresql://vetapp_app:app_password@localhost:5432/vetapp
# Usuário de migrações/admin (aplica DDL e políticas RLS)
DATABASE_ADMIN_URL=postgresql://vetapp_admin:admin_password@localhost:5432/vetapp

# ───────── Redis ─────────
REDIS_URL=redis://localhost:6379

# ───────── Auth ─────────
# Segredos fortes em produção (cofre/secret manager — NUNCA commitar)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # 15 min
JWT_REFRESH_TTL=2592000       # 30 dias

# ───────── Login com Google (OIDC) — opcional ─────────
# Client ID OAuth do Google Cloud Console (tipo Web). O MESMO valor vai nas duas
# vars: o back valida o id_token; o front renderiza o botão.
#GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
#NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# ───────── Object storage (Cloudflare R2 / S3-compatível) ─────────
# Em dev local pode-se apontar para o MinIO do docker-compose.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=vetapp-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
